+    set(_GAUXC_PREV_CMAKE_POLICY_DEFAULT_CMP0144 "${CMAKE_POLICY_DEFAULT_CMP0144}")
+  endif()
+  set(CMAKE_POLICY_DEFAULT_CMP0144 NEW)
+endif()
@@ -93,0 +102,9 @@ endif()
+if(POLICY CMP0144)
+  if(DEFINED _GAUXC_PREV_CMAKE_POLICY_DEFAULT_CMP0144)
+    set(CMAKE_POLICY_DEFAULT_CMP0144 "${_GAUXC_PREV_CMAKE_POLICY_DEFAULT_CMP0144}")
+  else()
+    unset(CMAKE_POLICY_DEFAULT_CMP0144)
