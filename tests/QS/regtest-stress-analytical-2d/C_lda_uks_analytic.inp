&GLOBAL
  PRINT_LEVEL LOW
  PROJECT C
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES F
  DEBUG_STRESS_TENSOR T
&END DEBUG

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    CHARGE 0
    MULTIPLICITY 1
    POTENTIAL_FILE_NAME POTENTIAL
    UKS
    &MGRID
      CUTOFF 200
      REL_CUTOFF 30
    &END MGRID
    &POISSON
      PERIODIC XY
      PSOLVER ANALYTIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION GEXT_PROJ
    &END QS
    &SCF
      EPS_SCF 1.0E-08
      MAX_SCF 60
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        ALPHA 0.4
        METHOD BROYDEN_MIXING
        NBROYDEN 8
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
    &XC
      &XC_FUNCTIONAL PADE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &PRINT
    &STRESS_TENSOR ON
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      A 2.42729600 0.00000000 0.00000000
      B -1.21364800 2.10210000 0.00000000
      C 0.00000000 0.00000000 6.00000000
      PERIODIC XY
    &END CELL
    &COORD
      C           2.41712615    0.01105341    3.00000000
      C          -0.01016984    1.41245342    3.00000000
    &END COORD
    &KIND C
      BASIS_SET SZV-MOLOPT-SR-GTH-q4
      ELEMENT C
      POTENTIAL GTH-PADE
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
