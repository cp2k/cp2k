&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT h2o-gapw_xc-full-stress-debug-1
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES .FALSE.
  DEBUG_STRESS_TENSOR .TRUE.
  DX 0.0005
  MAX_RELATIVE_ERROR 5.00
  STOP_ON_MISMATCH T
&END DEBUG

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR ANALYTICAL
  &DFT
    BASIS_SET_FILE_NAME "BASIS_SET"
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 240
      REL_CUTOFF 40
    &END MGRID
    &PRINT
      &DERIVATIVES
      &END DERIVATIVES
    &END PRINT
    &QS
      ALPHA_WEIGHTS 6.5
      EPS_DEFAULT 1.0E-10
      FORCE_PAW
      GAPW_1C_BASIS EXT_SMALL
      GAPW_ACCURATE_XCINT T
      METHOD GAPW_XC
    &END QS
    &SCF
      EPS_SCF 1.0E-7
      SCF_GUESS ATOMIC
    &END SCF
    &XC
      DENSITY_CUTOFF 1.0e-11
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      A 5.0 0.0 0.0
      B 0.25 5.1 0.0
      C 0.15 0.35 5.2
    &END CELL
    &COORD
      O   0.110000    0.170000   -0.045587
      H   0.260000   -0.627136    0.570545
      H  -0.180000    0.897136    0.440545
    &END COORD
    &KIND H
      BASIS_SET DZVP-GTH-PADE
      POTENTIAL GTH-PADE-q1
    &END KIND
    &KIND O
      BASIS_SET DZVP-GTH-PADE
      POTENTIAL GTH-PADE-q6
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
