&GLOBAL
  PRINT_LEVEL LOW
  PROJECT h2o-fine-tpss-stress-debug-1
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES .FALSE.
  DEBUG_STRESS_TENSOR .TRUE.
  DX 0.0005
  MAX_RELATIVE_ERROR 1.00
  STOP_ON_MISMATCH T
&END DEBUG

&FORCE_EVAL
  METHOD Quickstep
  STRESS_TENSOR DIAGONAL_ANALYTICAL
  &DFT
    BASIS_SET_FILE_NAME "BASIS_SET"
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 100
      REL_CUTOFF 40
    &END MGRID
    &PRINT
      &DERIVATIVES
      &END DERIVATIVES
    &END PRINT
    &QS
      ALPHA_WEIGHTS 6.5
      EPS_DEFAULT 1.0E-10
      FORCE_PAW
      GAPW_1C_BASIS EXT_SMALL
      GAPW_ACCURATE_XCINT T
      METHOD GAPW
    &END QS
    &SCF
      EPS_SCF 1.0E-5
      SCF_GUESS ATOMIC
    &END SCF
    &XC
      DENSITY_CUTOFF 1.0e-10
      &XC_FUNCTIONAL TPSS
      &END XC_FUNCTIONAL
      &XC_GRID
        USE_FINER_GRID
      &END XC_GRID
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 4.0 4.0 4.0
    &END CELL
    &COORD
      O   0.000000    0.000000   -0.065587
      H   0.000000   -0.757136    0.520545
      H   0.000000    0.757136    0.520545
    &END COORD
    &KIND H
      BASIS_SET DZVP-GTH-PADE
      POTENTIAL GTH-PADE-q1
    &END KIND
    &KIND O
      BASIS_SET DZVP-GTH-PADE
      POTENTIAL GTH-PADE-q6
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
