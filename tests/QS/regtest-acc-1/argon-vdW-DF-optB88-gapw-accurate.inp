&GLOBAL
  PRINT_LEVEL LOW
  PROJECT argon-vdW-DF-optB88-gapw-accurate
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  STRESS_TENSOR ANALYTICAL
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 200
    &END MGRID
    &QS
      GAPW_1C_BASIS EXT_SMALL
      GAPW_ACCURATE_XCINT T
      METHOD GAPW
    &END QS
    &SCF
      EPS_SCF 1.0e-6
      MAX_SCF 20
      SCF_GUESS ATOMIC
    &END SCF
    @XCTYPE vdW-DF-optB88
  &END DFT
  &PRINT
    &STRESS_TENSOR
      COMPONENTS
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      ABC 5.3 5.3 5.3
      ALPHA_BETA_GAMMA 90 90 90
    &END CELL
    &COORD
      SCALED .TRUE.
      Ar 0.0 0.0 0.0
      Ar 0.5 0.5 0.0
      Ar 0.5 0.0 0.5
      Ar 0.0 0.5 0.5
    &END COORD
    &KIND Ar
      BASIS_SET DZVP-MOLOPT-SR-GTH-q8
      POTENTIAL GTH-PADE-q8
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
