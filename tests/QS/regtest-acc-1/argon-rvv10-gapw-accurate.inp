&GLOBAL
  PRINT_LEVEL LOW
  PROJECT argon-rvv10-gapw-accurate
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  STRESS_TENSOR ANALYTICAL
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 180
    &END MGRID
    &QS
      GAPW_1C_BASIS EXT_SMALL
      GAPW_ACCURATE_XCINT T
      METHOD GAPW
    &END QS
    &SCF
      EPS_SCF 1.0e-5
      MAX_SCF 20
      SCF_GUESS ATOMIC
    &END SCF
    &XC
      &VDW_POTENTIAL
        DISPERSION_FUNCTIONAL NON_LOCAL
        &NON_LOCAL
          CUTOFF 40
          KERNEL_FILE_NAME rVV10_kernel_table.dat
          PARAMETERS 6.3 0.0093
          TYPE RVV10
          VERBOSE_OUTPUT
        &END NON_LOCAL
      &END VDW_POTENTIAL
      &XC_FUNCTIONAL
        &GGA_C_PBE
        &END GGA_C_PBE
        &GGA_X_RPW86
        &END GGA_X_RPW86
      &END XC_FUNCTIONAL
      &XC_GRID
        USE_FINER_GRID
      &END XC_GRID
    &END XC
  &END DFT
  &PRINT
    &STRESS_TENSOR
      COMPONENTS
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      ABC 5.31 5.31 5.31
      ALPHA_BETA_GAMMA 90 90 90
    &END CELL
    &COORD
      SCALED .TRUE.
      Ar 0.1 0.0 0.0
      Ar 0.5 0.5 0.0
      Ar 0.5 0.0 0.5
      Ar 0.0 0.5 0.5
    &END COORD
    &KIND Ar
      BASIS_SET DZVP-MOLOPT-SR-GTH-q8
      POTENTIAL GTH-PADE-q8
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
