&GLOBAL
  PRINT_LEVEL LOW
  PROJECT h2o-uzh-gapw-force-1
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  CHECK_ATOM_FORCE 1 x
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR F
  DX 0.0005
  MAX_RELATIVE_ERROR 0.10
  STOP_ON_MISMATCH T
&END DEBUG

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    POTENTIAL_FILE_NAME POTENTIAL_UZH
    &MGRID
      CUTOFF 240
      NGRIDS 5
      REL_CUTOFF 40
    &END MGRID
    &QS
      ALPHA_WEIGHTS 6.5
      EPS_DEFAULT 1.0E-10
      GAPW_ACCURATE_XCINT T
      METHOD GAPW
    &END QS
    &SCF
      EPS_SCF 1.0E-7
      MAX_SCF 80
      SCF_GUESS ATOMIC
    &END SCF
    &XC
      DENSITY_CUTOFF 1.0E-11
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      A 5.0 0.0 0.0
      B 0.25 5.1 0.0
      C 0.15 0.35 5.2
    &END CELL
    &COORD
      O   0.110000    0.170000   -0.045587
      H   0.260000   -0.627136    0.570545
      H  -0.180000    0.897136    0.440545
    &END COORD
    &KIND H
      BASIS_SET SVP-MOLOPT-PBE-ae
      POTENTIAL ALL
    &END KIND
    &KIND O
      BASIS_SET SVP-MOLOPT-PBE-ae
      POTENTIAL ALL
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
