&GLOBAL
  PRINT_LEVEL LOW
  PROJECT h2_gth_casino
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 100
      REL_CUTOFF 30
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER MT
    &END POISSON
    &PRINT
      &CASINO
        FILENAME gwfn.data
        WRITE_PSEUDOPOTENTIALS F
      &END CASINO
    &END PRINT
    &QS
      METHOD GPW
    &END QS
    &SCF
      ADDED_MOS 20
      EPS_SCF 1.0E-6
      MAX_SCF 80
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING
        ALPHA 0.4
        METHOD BROYDEN_MIXING
      &END MIXING
    &END SCF
    &XC
      &XC_FUNCTIONAL BLYP
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.0 5.0 5.0
      PERIODIC NONE
    &END CELL
    &COORD
      H   0.000000  0.000000  0.373334
      H   0.000000  0.000000 -0.373334
    &END COORD
    &KIND H
      BASIS_SET DZVP-MOLOPT-GTH
      POTENTIAL GTH-BLYP-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
