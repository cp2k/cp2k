&GLOBAL
  PRINT_LEVEL SILENT
  PROJECT RIRS-G0W0-PBE0-H2O
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_AUG_MOLOPT
    BASIS_SET_FILE_NAME BASIS_RI_AUG_MOLOPT
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 500
      REL_CUTOFF 50
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER MULTIPOLE
    &END POISSON
    &QS
      METHOD GAPW
    &END QS
    &SCF
      EPS_SCF 1E-7
      MAX_SCF 500
      SCF_GUESS ATOMIC
      &DIAGONALIZATION ON
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING T
        ALPHA 0.2
        BETA 1.5
        METHOD BROYDEN_MIXING
        NBUFFER 8
      &END MIXING
    &END SCF
    &XC
      &HF
        FRACTION 0.2500000
        &SCREENING
          EPS_SCHWARZ 1.0E-6
          SCREEN_ON_INITIAL_P FALSE
        &END SCREENING
      &END HF
      &XC_FUNCTIONAL
        &PBE
          SCALE_C 1.0000000
          SCALE_X 0.7500000
        &END PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &PROPERTIES
    &BANDSTRUCTURE
      &GW
        CUTOFF_RADIUS_RI 10
        EPS_FILTER 1.0E-10
        HEDIN_SHIFT T
        MEMORY_PER_PROC 14
        NUM_TIME_FREQ_POINTS 20
      &END GW
      &GW_RI_RS
        GRID_SELECT 1
      &END GW_RI_RS
    &END BANDSTRUCTURE
  &END PROPERTIES
  &SUBSYS
    &CELL
      ABC 6 6 6
      MULTIPLE_UNIT_CELL 1 1 1
      PERIODIC NONE
    &END CELL
    &COORD
      O  0.0000 0.0000 0.0000
      H  0.7571 0.0000 0.5861
      H -0.7571 0.0000 0.5861
    &END COORD
    &KIND H
      BASIS_SET aug-SZV-MOLOPT-ae
      BASIS_SET RI_AUX RI_aug-DZVP-MOLOPT-ae_N_RI_019_s_p_d_f_g_h_i_5_3_1_0_0_0_0_error_1.5e-07
      POTENTIAL ALL
    &END KIND
    &KIND O
      BASIS_SET aug-SZV-MOLOPT-ae
      BASIS_SET RI_AUX RI_aug-DZVP-MOLOPT-ae_N_RI_105_s_p_d_f_g_h_i_7_6_5_4_3_0_0_error_4.7e-07
      POTENTIAL ALL
    &END KIND
    &TOPOLOGY
      MULTIPLE_UNIT_CELL 1 1 1
      &CENTER_COORDINATES
      &END CENTER_COORDINATES
    &END TOPOLOGY
  &END SUBSYS
&END FORCE_EVAL
