&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    BASIS_SET_FILE_NAME BASIS_RI_MOLOPT
    POTENTIAL_FILE_NAME POTENTIAL 
    &MGRID
      CUTOFF 500
      REL_CUTOFF 50
    &END MGRID

    &QS 
      METHOD GPW
    &END

    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1E-7
      MAX_SCF 500
      &DIAGONALIZATION  ON
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING  T
         METHOD  BROYDEN_MIXING
         ALPHA    0.2
         BETA     1.5
         NBUFFER  8
       &END MIXING
    &END SCF   

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC

    &POISSON
       PERIODIC NONE
       POISSON_SOLVER MULTIPOLE
    &END

  &END DFT

  &PROPERTIES
      &BANDSTRUCTURE
      &GW
        NUM_TIME_FREQ_POINTS         20
        MEMORY_PER_PROC              14
        EPS_FILTER              1.0E-10
        CUTOFF_RADIUS_RI             10
        HEDIN_SHIFT                   T
      &END GW
      &GW_RI_RS
          GRID_SELECT 1
      &END GW_RI_RS
    &END BANDSTRUCTURE
  &END PROPERTIES
  
  &SUBSYS
    &CELL
      PERIODIC NONE
      ABC  6 6 6
      MULTIPLE_UNIT_CELL  1 1 1
    &END CELL
    &COORD
      O  0.0000 0.0000 0.0000
      H  0.7571 0.0000 0.5861
      H -0.7571 0.0000 0.5861
    &END COORD
    &TOPOLOGY
      &CENTER_COORDINATES
      &END
      MULTIPLE_UNIT_CELL  1 1 1
    &END
    &KIND H
      BASIS_SET SZV-MOLOPT-GTH
      BASIS_SET RI_AUX RI_63_7_7_7_0_0_0_0_4.6e-07
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND O
      BASIS_SET SZV-MOLOPT-GTH
      BASIS_SET RI_AUX RI_154_7_8_8_8_3_0_0_1.0e-08
      POTENTIAL GTH-PBE-q6
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
&GLOBAL
  RUN_TYPE     ENERGY
  PROJECT      RIRS-G0W0-GTH-PBE-H2O
  PRINT_LEVEL  SILENT
&END GLOBAL
