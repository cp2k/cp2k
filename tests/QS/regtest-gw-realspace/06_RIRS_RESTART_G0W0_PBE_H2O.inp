&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_AUG_MOLOPT
    BASIS_SET_FILE_NAME BASIS_RI_AUG_MOLOPT
    POTENTIAL_FILE_NAME POTENTIAL 
    &MGRID
      CUTOFF 500
      REL_CUTOFF 50
    &END MGRID

    &QS 
      METHOD GAPW
    &END

    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1E-7
      MAX_SCF 500
      &DIAGONALIZATION  ON
        ALGORITHM STANDARD
      &END DIAGONALIZATION
      &MIXING  T
         METHOD  BROYDEN_MIXING
         ALPHA    0.2
         BETA     1.5
         NBUFFER  8
       &END MIXING
    &END SCF   

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC

    &POISSON
       PERIODIC NONE
       POISSON_SOLVER MULTIPOLE
    &END

  &END DFT

  &PROPERTIES
      &BANDSTRUCTURE
      &GW
        NUM_TIME_FREQ_POINTS         20
        MEMORY_PER_PROC              14
        EPS_FILTER              1.0E-10
        CUTOFF_RADIUS_RI             10
        HEDIN_SHIFT                   T
      &END GW
      &GW_RI_RS
          GRID_SELECT 1
      &END GW_RI_RS
    &END BANDSTRUCTURE
  &END PROPERTIES
  
  &SUBSYS
    &CELL
      PERIODIC NONE
      ABC  6 6 6
      MULTIPLE_UNIT_CELL  1 1 1
    &END CELL
    &COORD
      O  0.0000 0.0000 0.0000
      H  0.7650 0.0000 0.5922
      H -0.7650 0.0000 0.5922
    &END COORD
    &TOPOLOGY
      &CENTER_COORDINATES
      &END
      MULTIPLE_UNIT_CELL  1 1 1
    &END
    &KIND H
      BASIS_SET aug-SZV-MOLOPT-ae
      BASIS_SET RI_AUX RI_aug-DZVP-MOLOPT-ae_N_RI_019_s_p_d_f_g_h_i_5_3_1_0_0_0_0_error_1.5e-07
      POTENTIAL ALL
    &END KIND
    &KIND O
      BASIS_SET aug-SZV-MOLOPT-ae
      BASIS_SET RI_AUX RI_aug-DZVP-MOLOPT-ae_N_RI_105_s_p_d_f_g_h_i_7_6_5_4_3_0_0_error_4.7e-07
      POTENTIAL ALL
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
&GLOBAL
  RUN_TYPE     ENERGY
  PROJECT      RIRS-RESTART-G0W0-PBE-H2O
  PRINT_LEVEL  SILENT
&END GLOBAL
