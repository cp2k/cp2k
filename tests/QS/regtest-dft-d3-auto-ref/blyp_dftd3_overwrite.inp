&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT dftd3_blyp_overwrite
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME GTH_BASIS_SETS
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    &MGRID
      CUTOFF 300
      REL_CUTOFF 30
    &END MGRID
    &POISSON
      PERIODIC none
      POISSON_SOLVER MT
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
    &END QS
    &SCF
      EPS_SCF 1.0E-6
      MAX_SCF 40
      SCF_GUESS ATOMIC
      &OT ON
        MINIMIZER DIIS
        PRECONDITIONER FULL_ALL
      &END OT
      &OUTER_SCF
        EPS_SCF 1.0E-6
        MAX_SCF 10
      &END OUTER_SCF
    &END SCF
    &XC
      &VDW_POTENTIAL
        DISPERSION_FUNCTIONAL PAIR_POTENTIAL
        &PAIR_POTENTIAL
          PARAMETER_FILE_NAME dftd3.dat
          REFERENCE_FUNCTIONAL PBE
          TYPE DFTD3
          &PRINT_DFTD
          &END PRINT_DFTD
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
      &XC_FUNCTIONAL BLYP
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 7.0 7.0 7.0
      PERIODIC NONE
    &END CELL
    &KIND H
      BASIS_SET DZVP-GTH-q1
      POTENTIAL GTH-BLYP-q1
    &END KIND
    &KIND C
      BASIS_SET DZVP-GTH-q4
      POTENTIAL GTH-BLYP-q4
    &END KIND
    &COORD
      C         0.000000        0.000000        0.000000
      H         0.629118        0.629118        0.629118
      H        -0.629118       -0.629118        0.629118
      H        -0.629118        0.629118       -0.629118
      H         0.629118       -0.629118       -0.629118
    &END COORD
  &END SUBSYS
&END FORCE_EVAL