&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT dftd3_pbe0_auto
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    POTENTIAL_FILE_NAME POTENTIAL_UZH
    &MGRID
      CUTOFF 300
      REL_CUTOFF 30
    &END MGRID
    &POISSON
      PERIODIC none
      POISSON_SOLVER MT
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
    &END QS
    &SCF
      EPS_SCF 1.0E-6
      MAX_SCF 40
      SCF_GUESS ATOMIC
      &OT ON
        MINIMIZER DIIS
        PRECONDITIONER FULL_ALL
      &END OT
      &OUTER_SCF
        EPS_SCF 1.0E-6
        MAX_SCF 10
      &END OUTER_SCF
    &END SCF
    &XC
      &VDW_POTENTIAL
        DISPERSION_FUNCTIONAL PAIR_POTENTIAL
        &PAIR_POTENTIAL
          PARAMETER_FILE_NAME dftd3.dat
          TYPE DFTD3
          &PRINT_DFTD
          &END PRINT_DFTD
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
      &XC_FUNCTIONAL PBE0
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.0 5.0 5.0
    &END CELL
    &KIND H
      BASIS_SET DZVP-MOLOPT-PBE0-GTH-q1
      POTENTIAL GTH-PBE0-q1
    &END KIND
    &KIND O
      BASIS_SET DZVP-MOLOPT-PBE0-GTH-q6
      POTENTIAL GTH-PBE0-q6
    &END KIND
    &KIND N
      BASIS_SET DZVP-MOLOPT-PBE0-GTH-q5
      POTENTIAL GTH-PBE0-q5
    &END KIND
    &COORD
      N   0.000000    0.000000    0.000000
      H   0.000000   -0.938000    0.380000
      H   0.000000    0.938000    0.380000
      H   0.000000    0.000000   -0.960000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL