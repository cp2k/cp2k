&GLOBAL
  PRINT_LEVEL LOW
  PROJECT H2_kp_tddfpt_none_general
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    POTENTIAL_FILE_NAME POTENTIAL_UZH
    &KPOINTS
      KPOINT -0.25 0.0 0.0 1.0
      KPOINT 0.25 0.0 0.0 1.0
      PARALLEL_GROUP_SIZE -1
      SCHEME GENERAL
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &MGRID
      CUTOFF 100
      REL_CUTOFF 30
    &END MGRID
    &QS
      EPS_DEFAULT 1.0E-10
      METHOD GPW
    &END QS
    &SCF
      ADDED_MOS 4
      CHOLESKY OFF
      EPS_EIGVAL 1.0E-8
      EPS_SCF 1.0E-8
      MAX_SCF 50
      SCF_GUESS ATOMIC
      &MIXING
        ALPHA 0.35
        METHOD BROYDEN_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &PROPERTIES
    &TDDFPT
      KERNEL NONE
      NSTATES 2
    &END TDDFPT
  &END PROPERTIES
  &SUBSYS
    &CELL
      ABC 6.0 6.0 6.0
    &END CELL
    &COORD
      H 2.65 3.00 3.00
      H 3.35 3.00 3.00
    &END COORD
    &KIND H
      BASIS_SET ORB DZVP-MOLOPT-GGA-GTH-q1
      POTENTIAL GTH-GGA-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
