&GLOBAL
  PRINT_LEVEL LOW
  PROJECT H2_kp_tddfpt_full_mp
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    POTENTIAL_FILE_NAME POTENTIAL_UZH
    &KPOINTS
      FULL_GRID ON
      GAMMA_CENTERED T
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 2 1 1
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &MGRID
      CUTOFF 100
      REL_CUTOFF 30
    &END MGRID
    &QS
      EPS_DEFAULT 1.0E-10
      METHOD GPW
    &END QS
    &SCF
      ADDED_MOS 4
      CHOLESKY OFF
      EPS_EIGVAL 1.0E-8
      EPS_SCF 1.0E-8
      MAX_SCF 50
      SCF_GUESS ATOMIC
      &MIXING
        ALPHA 0.35
        METHOD BROYDEN_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &PROPERTIES
    &TDDFPT
      KERNEL FULL
      NSTATES 4
    &END TDDFPT
  &END PROPERTIES
  &SUBSYS
    &CELL
      ABC 4.0 4.0 4.0
    &END CELL
    &COORD
      H 1.65 2.00 2.00
      H 2.35 2.00 2.00
    &END COORD
    &KIND H
      BASIS_SET ORB DZVP-MOLOPT-GGA-GTH-q1
      POTENTIAL GTH-GGA-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
