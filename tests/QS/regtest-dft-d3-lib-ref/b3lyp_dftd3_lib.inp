&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT dftd3_b3lyp_lib
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME BASIS_SET
    POTENTIAL_FILE_NAME POTENTIAL_UZH
    &MGRID
      CUTOFF 300
      REL_CUTOFF 30
    &END MGRID
    &POISSON
      PERIODIC none
      POISSON_SOLVER MT
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
    &END QS
    &SCF
      EPS_SCF 1.0E-6
      MAX_SCF 40
      SCF_GUESS ATOMIC
      &OT ON
        MINIMIZER DIIS
        PRECONDITIONER FULL_ALL
      &END OT
      &OUTER_SCF
        EPS_SCF 1.0E-6
        MAX_SCF 10
      &END OUTER_SCF
    &END SCF
    &XC
      &VDW_POTENTIAL
        DISPERSION_FUNCTIONAL PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3
          D3_REFERENCE_CODE
          &PRINT_DFTD
          &END PRINT_DFTD
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
      &XC_FUNCTIONAL B3LYP
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.0 5.0 5.0
    &END CELL
    &KIND F
      BASIS_SET DZVP-GTH-PADE
      POTENTIAL GTH-PBE0-q7
    &END KIND
    &COORD
      F   0.000000    0.000000   -0.700000
      F   0.000000    0.000000    0.700000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL