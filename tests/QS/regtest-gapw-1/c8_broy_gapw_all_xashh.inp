&GLOBAL
  FLUSH_SHOULD_FLUSH
  PRINT_LEVEL MEDIUM
  PROJECT c8_broy_xashh_c
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    BASIS_SET_FILE_NAME EMSL_BASIS_SETS
    LSD
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 100
      NGRIDS 4
    &END MGRID
    &PRINT
      &MO
        EIGENVALUES
        OCCUPATION_NUMBERS
        &EACH
          QS_SCF 100
        &END EACH
      &END MO
      ##      &MO_CUBES
      ##        NHOMO  64
      ##        NLUMO 20
      ##        WRITE_CUBE F
      ##      &END
    &END PRINT
    &QS
      EPS_DEFAULT 1.0E-11
      EXTRAPOLATION PS
      EXTRAPOLATION_ORDER 2
      METHOD GAPW
    &END QS
    &SCF
      ADDED_MOS 20 20
      EPS_SCF 5.0e-6
      MAX_SCF 50
      SCF_GUESS ATOMIC
      &MIXING
        ALPHA 0.4
        GMIX_P
        METHOD BROYDEN_MIXING
        NBROYDEN 8
      &END MIXING
      &SMEAR
        METHOD GAUSSIAN
        SIGMA [eV] 0.05
      &END SMEAR
    &END SCF
    &XAS
      ADDED_MOS 200
      ATOMS_LIST 3 4 5
      DIPOLE_FORM VELOCITY
      METHOD TP_HH
      STATE_SEARCH 16
      STATE_TYPE 1s
      &LOCALIZE
      &END LOCALIZE
      ##      RESTART
      ##      WFN_RESTART_FILE_NAME ./c8_broy_xashh
      &PRINT
        &PROGRAM_RUN_INFO
        &END PROGRAM_RUN_INFO
        &RESTART
          ADD_LAST NUMERIC
          FILENAME ./c8_broy_xashh
          &EACH
            XAS_SCF 15
          &END EACH
        &END RESTART
        &XAS_SPECTRUM
          FILENAME ./c8_broy_xashh
        &END XAS_SPECTRUM
        &XES_SPECTRUM
          FILENAME ./c8_broy_xashh
        &END XES_SPECTRUM
      &END PRINT
      &SCF
        EPS_SCF 5.0E-2
        MAX_SCF 60
        &MIXING
          ALPHA 0.4
          GMIX_P
          METHOD BROYDEN_MIXING
          NBROYDEN 8
        &END MIXING
        &SMEAR ON
          METHOD GAUSSIAN
          SIGMA [eV] 0.05
        &END SMEAR
      &END SCF
    &END XAS
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
  &END PRINT
  &SUBSYS
    &CELL
      ABC 5.42858871335 5.42858871335 5.42858871335
    &END CELL
    &KIND C
      BASIS_SET 6-31Gxx
      POTENTIAL ALL
    &END KIND
    &TOPOLOGY
      CONNECTIVITY OFF
      COORDINATE XYZ
      COORD_FILE_NAME ../sample_xyz/C_8.xyz
    &END TOPOLOGY
  &END SUBSYS
&END FORCE_EVAL
