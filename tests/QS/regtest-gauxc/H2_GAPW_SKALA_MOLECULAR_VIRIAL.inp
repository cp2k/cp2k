&GLOBAL
  PRINT_LEVEL LOW
  PROJECT_NAME H2_GAPW_SKALA_MOLECULAR_VIRIAL
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_SET
    MULTIPLICITY 1
    POTENTIAL_FILE_NAME POTENTIAL
    UKS FALSE
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER ANALYTIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      METHOD GAPW
    &END QS
    &SCF
      EPS_SCF 1.0E-8
      MAX_SCF 80
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          GRID SUPERFINE
          MODEL SKALA
          MOLECULAR_VIRIAL T
          MOLECULAR_VIRIAL_DEBUG T
          PRUNING_SCHEME UNPRUNED
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 6.0 6.0 6.0
      PERIODIC NONE
    &END CELL
    &COORD
      H 0.0 0.0 -0.4
      H 0.0 0.0  0.4
    &END COORD
    &KIND H
      BASIS_SET DZV-ALL-PADE
      POTENTIAL ALL
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
