&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT_NAME H2_GAPW_SKALA_CDFT
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_SET
    CHARGE 1
    MULTIPLICITY 2
    POTENTIAL_FILE_NAME POTENTIAL
    UKS TRUE
    &MGRID
      CUTOFF 200
      REL_CUTOFF 30
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER ANALYTIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-8
      GAPW_ACCURATE_XCINT T
      METHOD GAPW
      &CDFT
        STRENGTH -0.110488603068
        TARGET 0.2
        TYPE_OF_CONSTRAINT BECKE
        &ATOM_GROUP
          ATOMS 1 2
          COEFF 1 -1
          CONSTRAINT_TYPE CHARGE
        &END ATOM_GROUP
        &BECKE_CONSTRAINT
          CUTOFF_TYPE GLOBAL
          GLOBAL_CUTOFF 3.2
        &END BECKE_CONSTRAINT
        &OUTER_SCF
          EPS_SCF 5.0E-3
          MAX_SCF 10
          OPTIMIZER DIIS
          TYPE CDFT_CONSTRAINT
        &END OUTER_SCF
      &END CDFT
    &END QS
    &SCF
      EPS_SCF 1.0E-5
      MAX_SCF 40
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
      &OUTER_SCF
        EPS_SCF 1.0E-5
        MAX_SCF 2
      &END OUTER_SCF
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          GRID FINE
          MODEL SKALA
          PRUNING_SCHEME ROBUST
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 6.0 6.0 6.0
      PERIODIC NONE
    &END CELL
    &COORD
      H 0.0 0.0 -0.4
      H 0.0 0.0  0.4
    &END COORD
    &KIND H
      BASIS_SET DZV-ALL-PADE
      POTENTIAL ALL
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
