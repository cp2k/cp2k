&GLOBAL
  PRINT_LEVEL LOW
  PROJECT_NAME OH_ONEDFT_PBE_UKS
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    MULTIPLICITY 2
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    UKS TRUE
    &MGRID
      CUTOFF 150
      REL_CUTOFF 30
    &END MGRID
    &POISSON
      PERIODIC XYZ
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-8
      EXTRAPOLATION USE_PREV_WF
    &END QS
    &SCF
      EPS_SCF 1.0E-3
      MAX_SCF 40
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          MODEL PBE
          PERIODIC_REFERENCE T
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 6.0 6.0 6.0
      PERIODIC XYZ
    &END CELL
    &COORD
      O 3.0 3.0 3.0
      H 3.0 3.0 3.97
    &END COORD
    &KIND O
      BASIS_SET DZVP-MOLOPT-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND H
      BASIS_SET DZVP-MOLOPT-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
