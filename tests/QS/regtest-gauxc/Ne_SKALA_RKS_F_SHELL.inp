&GLOBAL
  PRINT_LEVEL LOW
  PROJECT_NAME Ne_SKALA_RKS_F_SHELL
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_SET
    MULTIPLICITY 1
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    UKS FALSE
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
    &END MGRID
    &POISSON
      PERIODIC XYZ
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION USE_PREV_WF
    &END QS
    &SCF
      EPS_SCF 1.0E-5
      MAX_SCF 80
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          GRID SUPERFINE
          MODEL SKALA
          PRUNING_SCHEME UNPRUNED
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 12.0 12.0 12.0
      PERIODIC XYZ
    &END CELL
    &COORD
      Ne 6.0 6.0 6.0
    &END COORD
    &KIND Ne
      BASIS_SET TZVDD3DF3PD-GTH-BLYP
      POTENTIAL GTH-PBE-q8
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
