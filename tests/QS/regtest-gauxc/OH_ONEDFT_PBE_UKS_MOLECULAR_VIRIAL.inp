&GLOBAL
  PRINT_LEVEL LOW
  PROJECT_NAME OH_ONEDFT_PBE_UKS_MOLECULAR_VIRIAL
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME GTH_BASIS_SETS
    MULTIPLICITY 2
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    UKS TRUE
    &MGRID
      CUTOFF 800
      REL_CUTOFF 60
    &END MGRID
    &POISSON
      PERIODIC XYZ
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION USE_PREV_WF
    &END QS
    &SCF
      EPS_SCF 1.0E-7
      MAX_SCF 80
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          GRID SUPERFINE
          MODEL PBE
          MOLECULAR_VIRIAL T
          MOLECULAR_VIRIAL_DEBUG T
          PRUNING_SCHEME UNPRUNED
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 12.0 12.0 12.0
      PERIODIC XYZ
    &END CELL
    &COORD
      O 6.000000 6.000000 5.525000
      H 6.000000 6.000000 6.475000
    &END COORD
    &KIND H
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND O
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
