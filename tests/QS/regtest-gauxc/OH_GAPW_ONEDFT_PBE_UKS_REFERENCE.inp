&GLOBAL
  PRINT_LEVEL LOW
  PROJECT_NAME OH_GAPW_ONEDFT_PBE_UKS_REFERENCE
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_SET
    MULTIPLICITY 2
    POTENTIAL_FILE_NAME POTENTIAL
    UKS TRUE
    &MGRID
      CUTOFF 800
      REL_CUTOFF 60
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER ANALYTIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      METHOD GAPW
    &END QS
    &SCF
      EPS_SCF 1.0E-8
      MAX_SCF 80
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &PBE
        &END PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 12.0 12.0 12.0
      PERIODIC NONE
    &END CELL
    &COORD
      O 0.000000 0.000000 -0.475000
      H 0.000000 0.000000  0.475000
    &END COORD
    &KIND H
      BASIS_SET 6-31G*
      POTENTIAL ALL
    &END KIND
    &KIND O
      BASIS_SET 6-31G*
      POTENTIAL ALL
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
