&GLOBAL
  PRINT_LEVEL LOW
  PROJECT_NAME H2O_GAPW_XC_GAUXC_PBE
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_SET
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 400
      NGRIDS 1
      REL_CUTOFF 50
    &END MGRID
    &QS
      ALPHA0_HARD 10
      EPSFIT 1.0E-4
      EPSISO 1.0E-12
      EPSRHO0 1.0E-8
      EPSSVD 0.0
      EPS_DEFAULT 1.0E-10
      EPS_GVG 1.0E-6
      EPS_PGF_ORB 1.0E-6
      LMAXN0 2
      LMAXN1 6
      METHOD GAPW_XC
      QUADRATURE GC_LOG
    &END QS
    &SCF
      EPS_SCF 1.0E-8
      MAX_SCF 80
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 6.0 6.0 6.0
    &END CELL
    &COORD
      O   0.000000    0.000000   -0.065587
      H   0.000000   -0.757136    0.520545
      H   0.000000    0.757136    0.520545
    &END COORD
    &KIND H
      BASIS_SET DZVP-GTH-PBE
      HARD_EXP_RADIUS 1.5117809071370015
      LEBEDEV_GRID 50
      POTENTIAL GTH-PBE-q1
      RADIAL_GRID 50
    &END KIND
    &KIND O
      BASIS_SET DZVP-GTH-PBE
      LEBEDEV_GRID 50
      POTENTIAL GTH-PBE-q6
      RADIAL_GRID 50
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
