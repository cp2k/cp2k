&GLOBAL
  PRINT_LEVEL LOW
  PROJECT_NAME NH3_ONEDFT_PBE_MOLECULAR_VIRIAL
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME GTH_BASIS_SETS
    MULTIPLICITY 1
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    UKS FALSE
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
    &END MGRID
    &POISSON
      PERIODIC XYZ
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION USE_PREV_WF
    &END QS
    &SCF
      EPS_SCF 1.0E-8
      MAX_SCF 80
      SCF_GUESS ATOMIC
      &DIAGONALIZATION
      &END DIAGONALIZATION
    &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          GRID SUPERFINE
          MODEL PBE
          MOLECULAR_VIRIAL T
          MOLECULAR_VIRIAL_DEBUG T
          PRUNING_SCHEME UNPRUNED
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 12.0 12.0 12.0
      PERIODIC XYZ
    &END CELL
    &COORD
      N 6.000000 6.000000 6.000000
      H 6.000000 6.937700 5.618000
      H 5.187900 5.531150 5.618000
      H 6.812100 5.531150 5.618000
    &END COORD
    &KIND H
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND N
      BASIS_SET DZVP-GTH
      POTENTIAL GTH-PBE-q5
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
