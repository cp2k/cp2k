&GLOBAL
  PROJECT almo-triplet-charge
  PRINT_LEVEL HIGH
  RUN_TYPE ENERGY
&END GLOBAL


&FORCE_EVAL
  METHOD QS

  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    CHARGE -1
    MULTIPLICITY 3
    UKS
    &MGRID
      COMMENSURATE
      CUTOFF 400
      NGRIDS 5
      REL_CUTOFF 50.
    &END MGRID

&QS
      ALMO_SCF T
      EPS_DEFAULT 1.0E-7 ! 1.0E-8
    &END QS

    &ALMO_SCF
      RETURN_ORTHOGONALIZED_MOS
      &FRAGMENT 1
       CHARGE 0
       MULTIPLICITY 3
      &END FRAGMENT
      &FRAGMENT 2
       CHARGE -1
       MULTIPLICITY 1
      &END FRAGMENT
      &ANALYSIS T
        FROZEN_MO_ENERGY_TERM    SUBLATTICE
        &PRINT
          &ALMO_EDA_CT
            FILENAME ct_energy_terms
          &END ALMO_EDA_CT
          &ALMO_CTA
            FILENAME charge_terms
          &END ALMO_CTA
        &END PRINT
      &END ANALYSIS

      EPS_FILTER                 1.0E-6 ! 1.0E-8
      ALMO_ALGORITHM             PCG
      ALMO_SCF_GUESS             MOLECULAR
           &ALMO_OPTIMIZER_PCG
        CONJUGATOR POLAK_RIBIERE
        EPS_ERROR 5.0E-4
        LIN_SEARCH_EPS_ERROR 0.05
        LIN_SEARCH_STEP_SIZE_GUESS 0.1
        MAX_ITER 50
        MAX_ITER_OUTER_LOOP 5
        PRECONDITIONER DEFAULT
      &END ALMO_OPTIMIZER_PCG
      DELOCALIZE_METHOD          NONE
    &END ALMO_SCF

 &SCF
      MAX_SCF 300
      SCF_GUESS ATOMIC
   &OT 
            PRECONDITIONER FULL_ALL 
            MINIMIZER CG
   &END OT
    &OUTER_SCF ! repeat the inner SCF cycle 10 times
      MAX_SCF 100
      EPS_SCF 1.0E-6 ! must match the above
    &END
    &END SCF

&XC 
        &XC_FUNCTIONAL NO_SHORTCUT
              &PBE T
              &END PBE
        &END XC_FUNCTIONAL
    &END XC

  &END DFT

  &SUBSYS
&CELL
ABC [angstrom] 4.5198722000    7.8286483000    7.3588725000
ALPHA_BETA_GAMMA [deg] 90.0000 90.000  90.0000
      PERIODIC XYZ
    &END CELL
  
    &KIND H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND

    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND

&TOPOLOGY
  CONNECTIVITY USER
&END TOPOLOGY
&COORD
O          3.21773        0.47515        0.27003 cluster 1
O          2.77435        0.84983        1.26385 cluster 1
O         -0.36240       -0.25144       -0.15781 environment 2
H          0.01871        0.62497        0.10144 environment 2
H          0.09406       -0.90447        0.43023 environment 2
O          3.02063        3.91532       -0.35959 environment 2
H          3.14769        4.49428        0.43364 environment 2
H          2.19585        3.40364       -0.16353 environment 2
O         -0.49878        5.41071        0.65477 environment 2
H          0.29563        5.29874        0.07448 environment 2
H         -0.15399        5.28329        1.57411 environment 2
O         -0.82753       -0.35640        4.83573 environment 2
H         -0.83016        0.45669        4.27047 environment 2
H         -0.31259       -0.09720        5.64089 environment 2
O          2.36943        1.16203        4.70479 environment 2
H          1.96531        0.50549        4.08351 environment 2
H          2.98274        1.69434        4.13828 environment 2
O          2.70460        4.62171        4.98198 environment 2
H          2.27109        4.36485        4.12948 environment 2
H          2.24244        4.07849        5.66897 environment 2
O         -0.52734        5.42946        4.61588 environment 2
H         -1.27023        4.99546        4.12570 environment 2
&END COORD
  &END SUBSYS
&END FORCE_EVAL
