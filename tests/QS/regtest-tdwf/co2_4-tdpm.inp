&GLOBAL
  PRINT_LEVEL LOW
  PROJECT ala2-tdwf
  RUN_TYPE RTP
&END GLOBAL

&MOTION
  &MD
    ENSEMBLE NVE
    STEPS 2
    TEMPERATURE 300.0
    TIMESTEP [au_t] 0.25
  &END MD
  &PRINT
    &TRAJECTORY
      &EACH
        MD 1
      &END EACH
    &END TRAJECTORY
  &END PRINT
&END MOTION

&FORCE_EVAL
  METHOD QUICKSTEP
  &DFT
    BASIS_SET_FILE_NAME BASIS_SET
    POTENTIAL_FILE_NAME POTENTIAL
    &LOCALIZE
      MAX_ITER 100
      METHOD CS
      OPERATOR PIPEK
      OUT_ITER_EACH 1
      &PRINT
        &WANNIER_CENTERS
          ADD_LAST NUMERIC
          COMMON_ITERATION_LEVELS 5
          FILENAME ""
          IONS+CENTERS .TRUE.
        &END WANNIER_CENTERS
        &WANNIER_STATES
          ADD_LAST NUMERIC
          COMMON_ITERATION_LEVELS 5
          FILENAME ""
        &END WANNIER_STATES
      &END PRINT
    &END LOCALIZE
    &MGRID
      CUTOFF 100
    &END MGRID
    &PRINT
      &MOMENTS
        ADD_LAST NUMERIC
        COMMON_ITERATION_LEVELS 5
        COM_NL .TRUE.
        FILENAME ""
        MAGNETIC .TRUE.
        MAX_MOMENT 2
        PERIODIC .FALSE.
        REFERENCE COM
        VEL_REPRS .TRUE.
      &END MOMENTS
    &END PRINT
    &QS
      EPS_DEFAULT 1.0E-10
    &END QS
    &REAL_TIME_PROPAGATION
      APPLY_DELTA_PULSE .TRUE.
      DELTA_PULSE_DIRECTION 1 0 0
      EPS_ITER 1.0E-9
      INITIAL_WFN SCF_WFN
      MAT_EXP TAYLOR
      MAX_ITER 5
    &END REAL_TIME_PROPAGATION
    &SCF
      EPS_SCF 1.0E-3
      MAX_SCF 60
      SCF_GUESS ATOMIC
      &OT ON
        ROTATION
      &END OT
      &OUTER_SCF
        EPS_SCF 1.0E-3
      &END OUTER_SCF
    &END SCF
    &XC
      &XC_FUNCTIONAL PADE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 14.0 24.278702929071397 16.183834499223575
    &END CELL
    &COORD
      C  7.00000 10.57416  8.09192  frag
      O  7.00000 10.13037  7.00000  frag
      O  7.00000 11.01796  9.18383  frag
      C  7.00000 16.83491  8.09192  env
      O  7.00000 16.39112  7.00000  env
      O  7.00000 17.27870  9.18383  env
      C  7.00000 13.70454  8.09192  env
      O  7.00000 13.26075  7.00000  env
      O  7.00000 14.14833  9.18383  env
      C  7.00000  7.44379  8.09192  env
      O  7.00000  7.00000  7.00000  env
      O  7.00000  7.88758  9.18383  env
    &END COORD
    &KIND H
      BASIS_SET DZVP-GTH-PBE
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND HX
      BASIS_SET DZVP-GTH-PBE
      ELEMENT H
      GHOST T
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND C
      BASIS_SET DZVP-GTH-PBE
      POTENTIAL GTH-PBE-q4
    &END KIND
    &KIND N
      BASIS_SET DZVP-GTH-PBE
      POTENTIAL GTH-PBE-q5
    &END KIND
    &KIND O
      BASIS_SET DZVP-GTH-PBE
      POTENTIAL GTH-PBE-q6
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
