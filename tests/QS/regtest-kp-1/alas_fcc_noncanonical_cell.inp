&GLOBAL
  PRINT_LEVEL LOW
  PROJECT ALAS_FCC_NONCANONICAL_CELL
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    POTENTIAL_FILE_NAME POTENTIAL_UZH
    &KPOINTS
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 2 2 2
    &END KPOINTS
    &MGRID
      CUTOFF 120
      REL_CUTOFF 40
    &END MGRID
    &QS
      EPS_DEFAULT 1.0E-10
      METHOD GPW
    &END QS
    &SCF
      CHOLESKY OFF
      EPS_EIGVAL 1.e-8
      EPS_SCF 1.0E-8
      MAX_SCF 40
      SCF_GUESS ATOMIC
      &MIXING
        ALPHA 0.30
        METHOD BROYDEN_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      A 0.0000 2.8300 2.8300
      B 2.8300 0.0000 2.8300
      C 2.8300 2.8300 0.0000
      PERIODIC XYZ
    &END CELL
    &COORD
      SCALED
      Al 0.00 0.00 0.00
      As 0.25 0.25 0.25
    &END COORD
    &KIND Al
      BASIS_SET DZVP-MOLOPT-PBE-GTH-q3
      POTENTIAL GTH-PBE-q3
    &END KIND
    &KIND As
      BASIS_SET DZVP-MOLOPT-PBE-GTH-q5
      POTENTIAL GTH-PBE-q5
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
