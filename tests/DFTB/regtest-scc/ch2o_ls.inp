&GLOBAL
  PRINT_LEVEL LOW
  PROJECT ch2o_ls
  RUN_TYPE ENERGY
&END GLOBAL

#CPQA INCLUDE DFTB/scc/scc_parameter
#CPQA INCLUDE ../uff_table
#CPQA INCLUDE DFTB/scc/oo.spl
#CPQA INCLUDE DFTB/scc/oc.spl
#CPQA INCLUDE DFTB/scc/oh.spl
#CPQA INCLUDE DFTB/scc/co.spl
#CPQA INCLUDE DFTB/scc/cc.spl
#CPQA INCLUDE DFTB/scc/ch.spl
#CPQA INCLUDE DFTB/scc/ho.spl
#CPQA INCLUDE DFTB/scc/hc.spl
#CPQA INCLUDE DFTB/scc/hh.spl
&FORCE_EVAL
  &DFT
    &LS_SCF
      EPS_FILTER 1.0E-7
      EPS_SCF 1.0E-8
      MATRIX_CLUSTER_TYPE ATOMIC
      MAX_SCF 50
      MU -0.20
      NON_MONOTONIC T
      PURIFICATION_METHOD TC2
      REPORT_ALL_SPARSITIES OFF
      S_PRECONDITIONER MOLECULAR
    &END LS_SCF
    &QS
      LS_SCF
      METHOD DFTB
      &DFTB
        DISPERSION T
        DO_EWALD F
        ORTHOGONAL_BASIS F
        SCC_MIXER CP2K
        SELF_CONSISTENT T
        &PARAMETER
          PARAM_FILE_NAME scc_parameter
          PARAM_FILE_PATH DFTB/scc
          UFF_FORCE_FIELD ../uff_table
        &END PARAMETER
      &END DFTB
    &END QS
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
      O     0.051368    0.000000    0.000000
      C     1.278612    0.000000    0.000000
      H     1.870460    0.939607    0.000000
      H     1.870460   -0.939607    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
