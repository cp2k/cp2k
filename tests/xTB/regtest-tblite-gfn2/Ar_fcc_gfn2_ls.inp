&GLOBAL
  PRINT_LEVEL LOW
  PROJECT Ar_fcc_gfn2_ls
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
    &LS_SCF
      EPS_FILTER 1.0E-7
      EPS_SCF 1.0E-8
      MATRIX_CLUSTER_TYPE ATOMIC
      MAX_SCF 50
      MU -0.20
      NON_MONOTONIC T
      PURIFICATION_METHOD TC2
      REPORT_ALL_SPARSITIES OFF
      S_PRECONDITIONER MOLECULAR
    &END LS_SCF
    &QS
      EPS_DEFAULT 1.00E-12
      LS_SCF
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.2600000000 5.2600000000 5.2600000000
      PERIODIC XYZ
    &END CELL
    &COORD
      SCALED
      Ar    0.113000    0.021000    0.037000
      Ar    0.486000    0.523000    0.014000
      Ar    0.517000    0.032000    0.491000
      Ar    0.029000    0.468000    0.546000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
