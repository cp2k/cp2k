&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Si_gfn2_kp_spglib_backend
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    &KPOINTS
      EPS_SYMMETRY 1.e-8
      FULL_GRID OFF
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 4 4 4
      SYMMETRY ON
      SYMMETRY_BACKEND SPGLIB
      VERBOSE T
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.00E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      ADDED_MOS -1 -1
      EPS_SCF 1.e-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
      &SMEAR ON
        ELECTRONIC_TEMPERATURE 300
        METHOD FERMI_DIRAC
      &END SMEAR
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.4310000000 5.4310000000000 5.431000000000
      PERIODIC XYZ
    &END CELL
    &COORD
      SCALED
      Si 0.000000 0.000000 0.000000
      Si 0.500000 0.500000 0.000000
      Si 0.500000 0.000000 0.500000
      Si 0.000000 0.500000 0.500000
      Si 0.250000 0.250000 0.250000
      Si 0.250000 0.750000 0.750000
      Si 0.750000 0.250000 0.750000
      Si 0.750000 0.750000 0.250000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
