&GLOBAL
  PRINT_LEVEL LOW
  PROJECT N2_gfn2_ls
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
    &LS_SCF
      EPS_FILTER 1.0E-7
      EPS_SCF 1.0E-8
      MATRIX_CLUSTER_TYPE ATOMIC
      MAX_SCF 50
      MU -0.20
      NON_MONOTONIC T
      PURIFICATION_METHOD TC2
      REPORT_ALL_SPARSITIES OFF
      S_PRECONDITIONER MOLECULAR
    &END LS_SCF
    &QS
      EPS_DEFAULT 1.00E-12
      LS_SCF
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
      N     0.000000    0.000000    0.000000
      N     1.000000    0.000000    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
