&GLOBAL
  PRINT_LEVEL LOW
  PROJECT N2_gfn2_ot
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
    &QS
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.e-8
      MAX_SCF 60
      SCF_GUESS MOPAC
      &OT
        MINIMIZER DIIS
        PRECONDITIONER FULL_SINGLE_INVERSE
      &END OT
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
      N     0.000000    0.000000    0.000000
      N     1.000000    0.000000    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
