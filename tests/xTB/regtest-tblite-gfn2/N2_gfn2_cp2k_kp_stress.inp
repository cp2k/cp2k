&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT N2_gfn2_cp2k_kp_stress
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES F
  DEBUG_STRESS_TENSOR T
  DX 0.0001
  MAX_RELATIVE_ERROR 0.5
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID OFF
      SCHEME MONKHORST-PACK 2 2 2
      SYMMETRY ON
      SYMMETRY_BACKEND SPGLIB
      VERBOSE T
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER CP2K
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      ADDED_MOS -1 -1
      EPS_SCF 1.0E-9
      MAX_SCF 200
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 4.0 4.0 4.0
      PERIODIC XYZ
    &END CELL
    &COORD
      N  0.417000  0.283000  0.191000
      N  1.517000  0.311000  0.203000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
