&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Si_gfn2_kp_333_stress
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES F
  DEBUG_STRESS_TENSOR T
  DX 0.0001
  MAX_RELATIVE_ERROR 0.5
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  STRESS_TENSOR DIAGONAL_ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID OFF
      SCHEME MONKHORST-PACK 3 3 3
      SYMMETRY ON
      VERBOSE T
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.00E-10
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      ADDED_MOS -1 -1
      EPS_SCF 1.e-8
      MAX_SCF 120
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
      &SMEAR ON
        ELECTRONIC_TEMPERATURE 300
        METHOD FERMI_DIRAC
      &END SMEAR
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.4310000000 5.4310000000000 5.431000000000
      PERIODIC XYZ
    &END CELL
    &COORD
      Si     0.00000000    0.00000000    0.00000000
      Si     2.71550000    2.71550000    0.00000000
      Si     2.71550000    0.00000000    2.71550000
      Si     0.00000000    2.71550000    2.71550000
      Si     1.35775000    1.35775000    1.35775000
      Si     1.35775000    4.10040500    4.10040500
      Si     4.10040500    1.35775000    4.10040500
      Si     4.10040500    4.10040500    1.35775000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
