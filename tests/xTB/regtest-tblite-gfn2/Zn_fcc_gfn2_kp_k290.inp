&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Zn_fcc_gfn2_kp_k290
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
    &KPOINTS
      EPS_GEO 1.0E-8
      FULL_GRID OFF
      SCHEME MONKHORST-PACK 3 3 3
      SYMMETRY ON
      VERBOSE T
    &END KPOINTS
    &QS
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      ADDED_MOS -1 -1
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
      &SMEAR
        ELECTRONIC_TEMPERATURE 300
        METHOD FERMI_DIRAC
      &END SMEAR
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 2.720887361806145 2.720887361806145 2.720887361806145
      ALPHA_BETA_GAMMA 60.0 60.0 60.0
      PERIODIC XYZ
    &END CELL
    &COORD
      Zn 0.0 0.0 0.0
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
