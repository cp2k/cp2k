&GLOBAL
  PRINT_LEVEL LOW
  PROJECT CH2O-cn-stress
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DE 0.0002
  DEBUG_DIPOLE F
  DEBUG_FORCES F
  DEBUG_POLARIZABILITY F
  DEBUG_STRESS_TENSOR T
  DX 0.0005
  EPS_NO_ERROR_CHECK 1.0E-7
  STOP_ON_MISMATCH T
&END DEBUG

&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &QS
      METHOD xTB
      &XTB
        COULOMB_INTERACTION F
        DO_EWALD T
        DO_NONBONDED F
        GFN_TYPE 1
        USE_HALOGEN_CORRECTION F
        VDW_POTENTIAL NONE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.0 5.0 5.0
    &END CELL
    &COORD
      O     0.051368    0.000000    0.000000
      C     1.278612    0.000000    0.000000
      H     1.870460    0.939607    0.000000
      H     1.870460   -0.939607    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
