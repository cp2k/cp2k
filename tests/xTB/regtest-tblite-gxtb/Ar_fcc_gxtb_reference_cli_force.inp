&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Ar_fcc_gxtb_reference_cli_force
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      SCHEME NONE
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.00E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GXTB
          &REFERENCE_CLI
            CHECK_FORCES T
            CHECK_VIRIAL T
            ERROR_LIMIT 2.0E-5
            PROGRAM_NAME tblite
            STOP_ON_ERROR T
          &END REFERENCE_CLI
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      IGNORE_CONVERGENCE_FAILURE T
      MAX_SCF 200
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.2600000000 5.2600000000 5.2600000000
      PERIODIC XYZ
    &END CELL
    &COORD
      SCALED
      Ar    0.113000    0.021000    0.037000
      Ar    0.486000    0.523000    0.014000
      Ar    0.517000    0.032000    0.491000
      Ar    0.029000    0.468000    0.546000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
