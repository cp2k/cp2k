&GLOBAL
  PRINT_LEVEL HIGH
  PROJECT COBe_gxtb_auto_reference_cli_stress
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &PRINT
      &MOMENTS ON
        PERIODIC .FALSE.
        REFERENCE COM
      &END MOMENTS
    &END PRINT
    &QS
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GXTB
          SCC_MIXER AUTO
          &REFERENCE_CLI
            PROGRAM_NAME tblite
            WORK_DIRECTORY ref-cli-cobe-stress
            CHECK_VIRIAL T
            ACCURACY 0.01
            ERROR_LIMIT 1.0E-6
          &END REFERENCE_CLI
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.e-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
      O    -0.564000    0.000000    0.000000
      C     0.564000    0.000000    0.000000
      Be    0.000000    4.000000    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
