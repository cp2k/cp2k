&GLOBAL
  PRINT_LEVEL LOW
  PROJECT Ar_fcc_gxtb_cell_opt
  RUN_TYPE CELL_OPT
&END GLOBAL

&MOTION
  &CELL_OPT
    EXTERNAL_PRESSURE 0.0
    MAX_DR 0.003
    MAX_FORCE 0.00045
    MAX_ITER 1
    OPTIMIZER CG
    RMS_DR 0.0015
    RMS_FORCE 0.0003
    TYPE DIRECT_CELL_OPT
    &CG
      &LINE_SEARCH
        TYPE 2PNT
      &END LINE_SEARCH
    &END CG
  &END CELL_OPT
&END MOTION

&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      SCHEME NONE
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.00E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      IGNORE_CONVERGENCE_FAILURE T
      MAX_SCF 200
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 5.2600000000 5.2600000000 5.2600000000
      PERIODIC XYZ
    &END CELL
    &COORD
      SCALED
      Ar    0.113000    0.021000    0.037000
      Ar    0.486000    0.523000    0.014000
      Ar    0.517000    0.032000    0.491000
      Ar    0.029000    0.468000    0.546000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
