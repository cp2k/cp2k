&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT H2O_gfn2_force
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR F
  DX 0.0001
&END DEBUG

&FORCE_EVAL
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 200
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
      H    -0.0121648342    0.0000000000   -0.9323517940
      H     0.8750977221    0.0000000000    0.3219980096
      O    -0.0543635745    0.0000000000    0.0384514415
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
