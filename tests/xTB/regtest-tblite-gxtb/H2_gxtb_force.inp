&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT H2_gxtb_force
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR F
  DX 0.00005
  EPS_NO_ERROR_CHECK 1.0E-7
&END DEBUG

&FORCE_EVAL
  &DFT
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER ANALYTIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GXTB
          SCC_MIXER TBLITE
          TBLITE_MIXER_DAMPING 0.2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.e-8
      MAX_SCF 200
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 12.0 12.0 12.0
      PERIODIC NONE
    &END CELL
    &COORD
      H     0.000000    0.000000    0.000000
      H     0.500000    0.400000    0.300000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
