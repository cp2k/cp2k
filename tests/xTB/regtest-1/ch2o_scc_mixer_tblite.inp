&GLOBAL
  PRINT_LEVEL LOW
  PROJECT ch2o_scc_mixer_tblite
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  &DFT
    &QS
      METHOD xTB
      &XTB
        COULOMB_INTERACTION T
        GFN_TYPE 1
        SCC_MIXER TBLITE
        TBLITE_MIXER_DAMPING 0.002
        &PARAMETER
          DISPERSION_PARAMETER_FILE dftd3.dat
        &END PARAMETER
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 500
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
      O     0.051368    0.000000    0.000000
      C     1.278612    0.000000    0.000000
      H     1.870460    0.939607    0.000000
      H     1.870460   -0.939607    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
