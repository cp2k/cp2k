&GLOBAL
  PRINT_LEVEL LOW
  PROJECT ch2o_tblite_oecorr
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    &QS
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GFN1
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.e-8
      MAX_SCF 100
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &PROPERTIES
    &TDDFPT
      CONVERGENCE [eV] 1.0e-7
      EV_SHIFT [eV] 0.5
      KERNEL sTDA
      MAX_ITER 50
      NSTATES 1
      OE_CORR SHIFT
      RKS_TRIPLETS F
      &STDA
        FRACTION 0.50
      &END STDA
    &END TDDFPT
  &END PROPERTIES
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC NONE
    &END CELL
    &COORD
      O     0.051368    0.000000    0.000000
      C     1.278612    0.000000    0.000000
      H     1.870460    0.939607    0.000000
      H     1.870460   -0.939607    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
