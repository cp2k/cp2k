      H -0.70648737841786 -2.17410164905906 1.59717234659556
      H 1.84971377940345 -1.34235639717661 1.59936176302322
      H 1.84863500728739 1.34499015079161 1.59918899520882
      C -0.97658096112243 0.7118425331789 -1.63138632255292
      C 0.37587390637791 1.15071653679839 -1.63028814098592
      C -0.97713437408181 -0.7100698747375 -1.63139739298304
      H -1.84767296055729 1.34488555954776 -1.59884933194674
      C 1.21123472478417 0.0000343387919 -1.62947531021637
      H 0.70918449672145 2.17462452492938 -1.59660160539228
      C 0.37498047250513 -1.1499957282639 -1.63031293852782
