&GLOBAL
  PRINT_LEVEL LOW
  PROJECT fcp
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
    LSD
    MULTIPLICITY 5
    &QS
      METHOD xTB
      &XTB
        CHECK_ATOMIC_CHARGES F
        GFN_TYPE 1
        SPIN_POLARISATION T
      &END XTB
    &END QS
    &SCF
      ADDED_MOS -1 -1
      EPS_SCF 1.e-7
      MAX_SCF 500
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.04
        #METHOD DIRECT_P_MIXING
      &END MIXING
      &SMEAR ON
        ELECTRONIC_TEMPERATURE 300
        FIXED_MAGNETIC_MOMENT -1
        METHOD Fermi_Dirac
      &END SMEAR
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 50.0 50.0 50.0
      PERIODIC NONE
    &END CELL
