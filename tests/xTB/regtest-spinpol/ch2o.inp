&GLOBAL
  PRINT_LEVEL LOW
  PROJECT CH2O
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    CHARGE 0
    LSD
    MULTIPLICITY 3
    &QS
      METHOD xTB
      &XTB
        CHECK_ATOMIC_CHARGES F
        SPIN_POLARISATION T
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.e-7
      MAX_SCF 100
      SCF_GUESS MOPAC
    &END SCF
  &END DFT
  &PRINT
    &FORCES
    &END FORCES
    &STRESS_TENSOR
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
    &END CELL
    &COORD
      O     0.051368    0.000000    0.000000
      C     1.278612    0.000000    0.000000
      H     1.870460    0.939607    0.000000
      H     1.870460   -0.939607    0.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
